{
  "name": "natemodi-site",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:logo-agent-data": "node scripts/build-logo-tools-json.mjs && node scripts/build-logo-explorer-json.mjs && node scripts/build-logo-agent-example.mjs",
    "eval:logo-agent-gallery": "node scripts/evaluate-logo-agent-gallery.mjs public/logo/examples/agent-gallery/gallery.json --brief tests/fixtures/logo-agent/vector-kit-brief.json --expected tests/fixtures/logo-agent/vector-kit.expected-summary.json --min-score 95",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/mdx": "^2.0.0",
    "astro": "^4.0.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "vitest": "^4.0.18"
  }
}
