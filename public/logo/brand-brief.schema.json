{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://natemodi.com/logo/brand-brief.schema.json",
  "title": "Logo Lab Brand Brief",
  "description": "Input brief an agent should parse before generating a Logo Lab gallery.",
  "type": "object",
  "required": ["companyName"],
  "additionalProperties": false,
  "properties": {
    "companyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Name of the company, product, or project."
    },
    "initials": {
      "type": "string",
      "maxLength": 8,
      "description": "Relevant initials or letters to explore."
    },
    "category": {
      "type": "string",
      "maxLength": 160,
      "description": "Product category, market, or industry."
    },
    "audience": {
      "type": "string",
      "maxLength": 240,
      "description": "Primary audience."
    },
    "brandAttributes": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 48
      },
      "examples": [["precise", "warm", "technical", "premium", "playful", "secure"]]
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/hexColor" },
        "foreground": { "$ref": "#/$defs/hexColor" },
        "accent": { "$ref": "#/$defs/hexColor" },
        "preferred": {
          "type": "array",
          "maxItems": 12,
          "items": { "$ref": "#/$defs/hexColor" }
        },
        "forbidden": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 48
          }
        }
      }
    },
    "styleConstraints": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      },
      "examples": [["must work in black and white", "must read at favicon size", "avoid gradients"]]
    },
    "competitors": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "outputCount": {
      "type": "integer",
      "minimum": 30,
      "maximum": 80,
      "default": 50
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#?[0-9a-fA-F]{6}$"
    }
  }
}

