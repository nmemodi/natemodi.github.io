---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Nate Modi — Building at the frontier of consumer behavior and emerging technology.' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, 'https://natemodi.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@nemodi" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-mono/style.css" />
  </head>
  <body>
    <header class="top-bar">
      <nav>
        <a href="/" class="logo-link"><img src="/n-logo.png" alt="N" class="nav-logo" /></a>
        <a href="/" class={currentPath === '/' ? 'active' : ''}>About</a>
        <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>Writing</a>
        <a href="/reading" class={currentPath === '/reading' ? 'active' : ''}>Reading</a>
        <div class="nav-dropdown">
          <span class={currentPath.startsWith('/line-warp') || currentPath.startsWith('/slept-on') ? 'active' : ''}>Etc.</span>
          <div class="nav-dropdown-menu">
            <a href="/slept-on">Slept On</a>
            <a href="/line-warp">Line Warp</a>
            <span class="nav-dropdown-disabled">Vector Plus</span>
            <span class="nav-dropdown-disabled">NFT CLI</span>
          </div>
        </div>
      </nav>
      <div class="status" id="status"></div>
    </header>

    <script>
      function getWeatherIcon(code) {
        const attrs = 'xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px"';
        const icons = {
          sun: `<svg ${attrs}><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`,
          cloudSun: `<svg ${attrs}><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M20 12h2"/><path d="m19.07 4.93-1.41 1.41"/><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"/></svg>`,
          cloud: `<svg ${attrs}><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>`,
          cloudRain: `<svg ${attrs}><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M16 14v6"/><path d="M8 14v6"/><path d="M12 16v6"/></svg>`,
          snowflake: `<svg ${attrs}><line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg>`,
          cloudLightning: `<svg ${attrs}><path d="M6 16.326A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 .5 8.973"/><path d="m13 12-3 5h4l-3 5"/></svg>`,
        };
        if (code === 0) return icons.sun;
        if (code <= 3) return icons.cloudSun;
        if (code <= 48) return icons.cloud;
        if (code <= 67) return icons.cloudRain;
        if (code <= 77) return icons.snowflake;
        if (code <= 86) return icons.snowflake;
        if (code >= 95) return icons.cloudLightning;
        return '';
      }

      function updateStatus() {
        const now = new Date();
        const time = now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        const date = now.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const el = document.getElementById('status');
        const temp = el?.dataset.temp || '';
        if (el) {
          const icon = el.dataset.weatherIcon || '';
          const parts = [time, date, temp].filter(Boolean);
          el.innerHTML = parts.join(' · ') + (icon ? ' ' + icon : '');
          wrapStatusChars();
        }
      }

      async function getLocation() {
        try {
          const res = await fetch('https://ipapi.co/json/');
          const data = await res.json();
          const el = document.getElementById('status');
          if (el && data.country_name) {
            el.dataset.location = data.country_name;

            // Countries that use Fahrenheit
            const fahrenheitCountries = ['United States', 'Bahamas', 'Cayman Islands', 'Liberia', 'Palau', 'Marshall Islands', 'Micronesia'];
            const useFahrenheit = fahrenheitCountries.includes(data.country_name);

            // Get temperature from Open-Meteo (free, no API key)
            if (data.latitude && data.longitude) {
              const unit = useFahrenheit ? 'fahrenheit' : 'celsius';
              const weatherRes = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${data.latitude}&longitude=${data.longitude}&current=temperature_2m,weather_code&temperature_unit=${unit}`);
              const weather = await weatherRes.json();
              if (weather.current?.temperature_2m) {
                const temp = Math.round(weather.current.temperature_2m);
                el.dataset.temp = useFahrenheit ? `${temp}°F` : `${temp}°C`;
                el.dataset.weatherIcon = getWeatherIcon(weather.current.weather_code) || '';
              }
            }
            updateStatus();
          }
        } catch (e) {
          // silently fail
        }
      }

      function wrapStatusChars() {
        const el = document.getElementById('status');
        if (!el) return;
        const html = el.innerHTML;
        let wrapped = '';
        let inTag = false;
        for (let i = 0; i < html.length; i++) {
          const ch = html[i];
          if (ch === '<') { inTag = true; wrapped += ch; continue; }
          if (ch === '>') { inTag = false; wrapped += ch; continue; }
          if (inTag) { wrapped += ch; continue; }
          if (ch === ' ') { wrapped += ' '; continue; }
          wrapped += `<span class="status-char">${ch}</span>`;
        }
        el.innerHTML = wrapped;
      }

      updateStatus();
      setInterval(updateStatus, 60000);
      getLocation();
    </script>
    <main>
      <slot />
    </main>
    <footer>
      <a href="/" class="footer-name">natemodi.com</a>
      <a href="https://x.com/nemodi" target="_blank" rel="noopener noreferrer">𝕏</a>
    </footer>
  </body>
</html>
