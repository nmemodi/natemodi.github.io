---
import BaseLayout from '../layouts/BaseLayout.astro';
import TravelList from '../components/TravelList.astro';
---

<BaseLayout title="Slept On" description="A travel aficionado's bucket list of overlooked places.">
  <article>
    <h1>Slept On</h1>
    <p class="meta">A travel aficionado's bucket list of overlooked places</p>
